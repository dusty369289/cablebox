# YouTube Data API v3 key — required for build:channels script
# Get one at https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" for the project
YOUTUBE_API_KEY=your_api_key_here

# Base path for GitHub Pages subdirectory hosting
# Set to /your-repo-name for username.github.io/your-repo-name
# Leave empty for root hosting
BASE_PATH=
